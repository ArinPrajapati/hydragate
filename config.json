{
  "jwt_secret": "update",
  "forward_claims": {
    "sub": "X-User-Id",
    "role": "X-User-Role"
  },
  "api_keys": {
    "test-key-1": "dev-client",
    "test-key-2": "mobile-app"
  },
  "rate_limit": {
    "enabled": true,
    "capacity": 15,
    "refill_rate": 100
  },
  "cache": {
    "enabled": false,
    "default_ttl": 300,
    "methods": ["GET"],
    "status_codes": [200, 304],
    "key": {
      "include_query": false,
      "include_headers": [],
      "respect_cache_control": true,
      "etag_validation": false
    },
    "max_size": 1048576
  },
  "routes": [
    {
      "route": "api",
      "target": "http://localhost:9000",
      "protected": false,
      "cache": {
        "enabled": false
      },
      "transform": {
        "add_headers": {
          "X-Proxied-By": "HydraGate",
          "X-Rate-Limit-Config": "true"
        },
        "remove_headers": ["User-Agent"],
        "path_rewrite": "*"
      },
      "cache_paths": [
        {
          "path": "/date",
          "enabled": true,
          "ttl": 5,
          "methods": ["GET"],
          "status_codes": [200],
          "key": {
            "include_query": false,
            "include_headers": []
          }
        }
      ]
    }
  ]
}
