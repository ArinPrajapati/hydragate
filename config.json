{
  "jwt_secret": "update",
  "forward_claims": {
    "sub": "X-User-Id",
    "role": "X-User-Role"
  },
  "api_keys": {
    "test-key-1": "dev-client",
    "test-key-2": "mobile-app"
  },
  "rate_limit": {
    "enabled": true,
    "capacity": 15,
    "refill_rate": 100
  },
  "cache": {
    "enabled": false,
    "default_ttl": 300,
    "methods": ["GET"],
    "status_codes": [200, 304],
    "key": {
      "include_query": false,
      "include_headers": [],
      "respect_cache_control": true,
      "etag_validation": false
    },
    "max_size": 1048576
  },
  "plugins": {
    "external_paths": [],
    "global": [
      {
        "name": "logger",
        "enabled": true,
        "priority": 100,
        "timeout_ms": 5000,
        "on_error": "continue"
      },
      {
        "name": "rate_limiter",
        "enabled": true,
        "priority": 50,
        "timeout_ms": 2000,
        "on_error": "abort"
      }
    ],
    "routes": {
      "api": [
        {
          "name": "api_key_auth",
          "enabled": false,
          "priority": 10,
          "timeout_ms": 1000,
          "on_error": "abort"
        },
        {
          "name": "jwt_auth",
          "enabled": false,
          "priority": 20,
          "timeout_ms": 1000,
          "on_error": "abort"
        }
      ]
    },
    "config": {
      "logger": {
        "level": "info"
      },
      "rate_limiter": {
        "capacity": 15,
        "refill_rate": 100
      },
      "api_key_auth": {},
      "jwt_auth": {}
    }
  },
  "routes": [
    {
      "route": "api",
      "target": "http://localhost:9000",
      "protected": false,
      "cache": {
        "enabled": false
      },
      "transform": {
        "add_headers": {
          "X-Proxied-By": "HydraGate",
          "X-Rate-Limit-Config": "true"
        },
        "remove_headers": ["User-Agent"],
        "path_rewrite": "*"
      },
      "cache_paths": [
        {
          "path": "/date",
          "enabled": true,
          "ttl": 5,
          "methods": ["GET"],
          "status_codes": [200],
          "key": {
            "include_query": false,
            "include_headers": []
          }
        }
      ]
    }
  ]
}
